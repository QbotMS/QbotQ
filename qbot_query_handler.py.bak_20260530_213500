def _expand_search_terms(raw_terms: list[str]) -> list[str]:
    """Expand search terms with PL→EN aliases."""
    expanded = []
    seen = set()
    for term in raw_terms:
        if term in seen:
            continue
        seen.add(term)
        expanded.append(term)
        aliases = GARAGE_ALIASES.get(term)
        if aliases:
            for a in aliases:
                if a not in seen:
                    seen.add(a)
                    expanded.append(a)
    return expanded


