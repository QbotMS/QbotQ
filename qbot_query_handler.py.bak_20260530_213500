    if r.get("duration_min") is not None:
        h, m = divmod(r["duration_min"], 60)
        parts.append(f"😴 Czas snu: {h}h {m}min")
    if r.get("score") is not None:
        parts.append(f"⭐ Jakość: {r['score']}/100")
