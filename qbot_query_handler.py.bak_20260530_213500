def _handle_training_recent(text: str) -> dict:
    days = 7
    m = re.search(r"ostatnie\s*(\d+)", text.lower())
    if m:
        days = int(m.group(1))
    since = _TODAY - timedelta(days=days)

    try:
        pg = _pg_conn()
        rows = _safe_fetch(pg, """
            SELECT date, started_at, sport_type, distance_m, duration_s, elevation_m,
                   avg_power_w, normalized_power_w, tss, avg_hr_bpm, activity_name
            FROM qbot_v2.training_sessions
            WHERE date >= %s
            ORDER BY date DESC, started_at DESC
        """, (since,))
        pg.close()
    except Exception as exc:
        return _envelope("training_recent", f"Błąd połączenia: {exc}", status_override="ERROR")

    if not rows or "_error" in rows[0]:
        return _envelope("training_recent", f"Brak treningów od {since}.")

    parts = [f"🏆 Treningi od {since} ({len(rows)} sesji):"]
    for r in rows:
        sport = r.get("sport_type") or "trening"
        dist = r.get("distance_m")
        dur_s = r.get("duration_s")
        dist_km = f"{dist/1000:.1f}km" if dist else ""
        dur_str = f"{dur_s//60}min" if dur_s else ""
        tss = r.get("tss")
        np = r.get("normalized_power_w")
        hr = r.get("avg_hr_bpm")
        line = f"   📅 {r['date']} {sport}"
        if dist_km or dur_str:
            line += f" — {dist_km} {dur_str}"
        if np:
            line += f" — NP {np:.0f}W"
        if tss:
            line += f" — TSS {tss:.0f}"
        if hr:
            line += f" — HR {hr}bpm"
        parts.append(line)

    answer = "\n".join(parts)
    data = {"count": len(rows), "rows": rows, "resolved_since": str(since), "resolved_days": days}
    return _envelope("training_recent", answer, data=data,
                     sources_used=["qbot_v2.training_sessions"],
                     freshness={"range_since": str(since), "range_days": days})


XERT_CACHE_TTL_HOURS = 2
XERT_LIVE_COOLDOWN_MINUTES = 10
XERT_LIVE_ATTEMPT_FILE = "/opt/qbot/app/tmp/xert_live_last_attempt.json"


def _xert_live_fetch() -> dict | None:
    """Live fetch from Xert API. Returns dict with ftp_watts/ltp_watts/w_prime_kj or None."""
    try:
        from qbot_api import _xert_sync_fetch
        import os
        email = os.getenv("XERT_EMAIL")
        pwd = os.getenv("XERT_PASSWORD")
        if not email or not pwd:
            return None
        result = _xert_sync_fetch(email, pwd)
        if result and result.get("ftp_watts") is not None:
            return result
        return None
    except Exception:
        return None


def _xert_save_snapshot(pg, data: dict) -> None:
    """Insert a new xert_profile_snapshot from live data."""
    import datetime as _dt_mod
    now = _dt_mod.datetime.now(_dt_mod.timezone.utc)
    pg.execute(
        """INSERT INTO qbot_v2.xert_profile_snapshots
           (snapshot_at, date, source, ftp_power_w, ltp_power_w, w_prime_kj, form_status, quality_status, raw_json, imported_at)
           VALUES (%s, %s, %s, %s, %s, %s, %s, %s, %s, %s)""",
        (now, now.date(), "query_vnext_live",
         data.get("ftp_watts"), data.get("ltp_watts"), data.get("w_prime_kj"),
         "live_fetch", "full",
         json.dumps(data, default=str), now),
    )
    pg.commit()


def _xert_read_last_attempt() -> dict | None:
    """Read the last live fetch attempt marker."""
    import os
    if not os.path.isfile(XERT_LIVE_ATTEMPT_FILE):
        return None
    try:
        with open(XERT_LIVE_ATTEMPT_FILE) as f:
            return json.load(f)
    except Exception:
        return None


def _xert_write_last_attempt(status: str, error_class: str = "") -> None:
    """Write a safe marker for the last live fetch attempt."""
    import datetime as _dt_mod
    import os
    os.makedirs(os.path.dirname(XERT_LIVE_ATTEMPT_FILE), exist_ok=True)
    try:
        with open(XERT_LIVE_ATTEMPT_FILE, "w") as f:
            json.dump({
                "attempted_at": _dt_mod.datetime.now(_dt_mod.timezone.utc).isoformat(),
                "status": status,
                "error_class": error_class,
            }, f)
    except Exception:
        pass


def _handle_xert_status(text: str) -> dict:
    freshness = {}
    source = "cache"
    fallback_reason = None
    warnings = []

    try:
        pg = _pg_conn()
        rows = _safe_fetch(pg, """
            SELECT * FROM qbot_v2.xert_profile_snapshots
            ORDER BY snapshot_at DESC NULLS LAST
            LIMIT 1
        """)
    except Exception as exc:
        return _envelope("xert_status", f"Błąd połączenia: {exc}", status_override="ERROR")

    import datetime as _dt_mod

    cached_row = None
    cache_age_minutes = None
    if rows and "_error" not in rows[0] and len(rows) > 0:
        cached_row = rows[0]
        if cached_row.get("snapshot_at"):
            snap = cached_row["snapshot_at"]
            if isinstance(snap, str):
                snap_dt = _dt_mod.datetime.fromisoformat(snap.replace("Z", "+00:00"))
            else:
                snap_dt = snap
            cache_age_minutes = (_dt_mod.datetime.now(_dt_mod.timezone.utc) - snap_dt).total_seconds() / 60.0

    # Cooldown check
    cooldown_active = False
    live_attempted = False
    last_attempt = _xert_read_last_attempt()
    if last_attempt:
        try:
            import datetime as _dt_mod2
            attempted_at = _dt_mod2.datetime.fromisoformat(last_attempt["attempted_at"])
            cooldown_min = (_dt_mod.datetime.now(_dt_mod.timezone.utc) - attempted_at).total_seconds() / 60.0
            if cooldown_min < XERT_LIVE_COOLDOWN_MINUTES:
                cooldown_active = True
        except Exception:
            pass

    # Decide whether to live fetch
    should_live_fetch = not cooldown_active and (
        cached_row is None
        or cache_age_minutes is None
        or cache_age_minutes > XERT_CACHE_TTL_HOURS * 60
    )

    if should_live_fetch:
        live_data = _xert_live_fetch()
        live_attempted = True
        if live_data:
            _xert_write_last_attempt("success")
            try:
                _xert_save_snapshot(pg, live_data)
                freshness["xert_fetched_at"] = _dt_mod.datetime.now(_dt_mod.timezone.utc).isoformat()
                source = "live"
                # Re-read the latest snapshot
                rows = _safe_fetch(pg, """
                    SELECT * FROM qbot_v2.xert_profile_snapshots
                    ORDER BY snapshot_at DESC NULLS LAST
                    LIMIT 1
                """)
                if rows and "_error" not in rows[0]:
                    cached_row = rows[0]
                    cache_age_minutes = 0
            except Exception as exc:
                _xert_write_last_attempt("save_error", type(exc).__name__)
                warnings.append(f"Nie udało się zapisać snapshotu: {exc}")
                source = "cache_stale_fallback" if cached_row else "live_fetch_no_save"
        else:
            _xert_write_last_attempt("failed", "api_error")
            if cached_row:
                source = "cache_stale_fallback"
                fallback_reason = "Live Xert API niedostępne — użyto cache"
                warnings.append("Live Xert fetch nie powiódł się — używam cache")
            else:
                pg.close()
                return _envelope("xert_status", "Brak danych Xert. Live fetch nie powiódł się i cache jest pusty.",
                                 missing_sources=["qbot_v2.xert_profile_snapshots", "xert_api"],
                                 warnings=["Live Xert fetch failed, no cache available"])
    elif cooldown_active and cached_row:
        source = "cache_stale_cooldown"
        fallback_reason = "Xert live fetch w cooldownie — użyto cache"
        warnings.append(f"Xert live fetch w cooldownie ({XERT_LIVE_COOLDOWN_MINUTES}min) — używam cache")

    if not cached_row:
        pg.close()
        return _envelope("xert_status", "Brak danych Xert.",
                         missing_sources=["qbot_v2.xert_profile_snapshots"])

    r = cached_row

    if r.get("snapshot_at"):
        freshness["xert_snapshot_at"] = str(r["snapshot_at"])
    if r.get("imported_at"):
        freshness["xert_imported_at"] = str(r["imported_at"])

    parts = []
    if r.get("ftp_power_w") is not None:
        parts.append(f"⚡ FTP: {r['ftp_power_w']:.0f}W")
    if r.get("ltp_power_w") is not None:
        parts.append(f"🔻 LTP: {r['ltp_power_w']:.0f}W")
    if r.get("w_prime_kj") is not None:
        parts.append(f"🔋 W': {r['w_prime_kj']:.1f}kJ")
    if r.get("form_status"):
        parts.append(f"📊 Forma: {r['form_status']}")
    if r.get("form_ratio") is not None:
        parts.append(f"📈 Form ratio: {r['form_ratio']:.3f}")
    if r.get("ts_rating") is not None:
        parts.append(f"🎯 TS: {r['ts_rating']:.3f}")

    if source == "live":
        parts.append(f"🔄 Live fetch: tak")
    elif source == "cache_stale_fallback":
        parts.append(f"🔄 Live fetch: niedostępny — użyto cache")
    parts.append(f"🕐 Snapshot: {r['snapshot_at']}")
    if cache_age_minutes is not None:
        parts.append(f"⏱ Wiek cache: {cache_age_minutes:.0f} min")

    if source == "cache_stale_cooldown":
        parts.append(f"🔄 Live fetch: cooldown aktywny")
    parts.append(f"🕐 Snapshot: {r['snapshot_at']}")
    if cache_age_minutes is not None:
        parts.append(f"⏱ Wiek cache: {cache_age_minutes:.0f} min")

    answer = "\n".join(parts) if parts else "Dane Xert — brak szczegółów."
    data = dict(r)
    data["resolved_date"] = str(r.get("date") or _TODAY)
    data["source_type"] = source
    data["cache_age_minutes"] = cache_age_minutes
    data["cooldown_active"] = cooldown_active
    data["live_attempted"] = live_attempted

    pg.close()
    return _envelope("xert_status", answer, data=data, sources_used=["qbot_v2.xert_profile_snapshots"],
                     freshness=freshness, warnings=warnings, fallback_reason=fallback_reason)


