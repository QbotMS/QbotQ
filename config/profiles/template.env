# Copy this file to config/profiles/<profile>.env and chmod 600.
# Do not commit or paste real tokens into logs.

PROFILE_NAME=profile_name
HAMMERHEAD_USER_ID=

# Hammerhead Dashboard:
# 1. Log in as this Hammerhead user.
# 2. Open browser console on dashboard.hammerhead.io.
# 3. Run: localStorage.getItem("jwt:refresh")
# 4. Paste the returned UUID below.
HAMMERHEAD_REFRESH_TOKEN=''

HAMMERHEAD_TOKENSTORE=/opt/qbot/app/.hammerhead_tokens/profile_name.json
GARMIN_TOKENSTORE=/opt/qbot/app/.garmin_tokens/profile_name
PROCESSED_STATE=/opt/qbot/app/state/profile_name_processed_hammerhead_activities.json
OUTGOING_DIR=/opt/qbot/app/outgoing/profile_name
QBOT_GARMIN_SYNC_MODE=upload
